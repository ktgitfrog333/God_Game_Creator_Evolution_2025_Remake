        private void Init()
        {
            var stub = stubSO.commons.homingObjectCustomizeViewModel._現在のトランザクション中のオバケボイスタイプが取得できること;
            var inputs = stub.inputs;
            var outputs = stub.outputs;
            if (inputs.Length == outputs.Length)
            {
                for (int i = 0; i < inputs.Length; i++)
                {
                    int caseId = i;
                    var model = inputs[caseId].playerModel;
                    if (model != null)
                    {
                        GhostInStaticObjectStruct target = model.TransactionGhostInStaticObjectStruct;
                        var ghostTeamID = model.ghostTeamID;
                        target.ghostTeamID.Value = ghostTeamID;
                    }
                }
            }
            _model = FindAnyObjectByType<PlayerModel>();
        }

