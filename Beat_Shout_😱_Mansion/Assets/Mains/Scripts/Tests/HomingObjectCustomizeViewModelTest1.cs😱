    public class HomingObjectCustomizeViewModelTest1 : MonoBehaviour
    {
        [SerializeField] private StubSO stubSO;
        private PlayerModel _model;
        // リフレクション用のフィールド情報（キャッシュ）
        private FieldInfo _playerModelField;

        private void Start()
        {
            Debug.Log($"HomingObjectCustomizeViewModelTest1 Start");
            Debug.Log($" - Section 0");
            Init();
