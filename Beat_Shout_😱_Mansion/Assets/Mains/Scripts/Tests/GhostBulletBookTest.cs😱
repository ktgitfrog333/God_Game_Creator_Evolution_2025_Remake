using Mains.Views;
using R3;
using System.Collections.Generic;
using UnityEngine;

namespace Mains.Tests
{
    public class GhostBulletBookTest : MonoBehaviour
    {
        [SerializeField] private Transform ghostTurretPosition;
        [SerializeField] private Transform ghostBulletWaitPosition;
        [SerializeField] private Transform player;
        [SerializeField] private Transform ghostBulletBookPrefab;
        [SerializeField] private Transform staticColldersInstance;
        private Transform _trans;
        /// <summary>R3のリソース管理</summary>
        private DisposableBag _disposableBag = new DisposableBag();

        private void Start()
        {
            _trans = transform;
        }

        private void OnGUI()
        {
            Rect buttonRect = new Rect(10, 10, 200, 50);
            if (GUI.Button(buttonRect, "GhostBulletBook Test"))
            {
                if (ghostBulletWaitPosition == null || player == null || ghostBulletBookPrefab == null)
                {
                    Debug.LogWarning("GhostBulletBookTest: 参照が未設定です。");
                    return;
                }
                var instance = Instantiate(ghostBulletBookPrefab, _trans.position, Quaternion.identity);
                instance.eulerAngles = _trans.eulerAngles;
                if (ghostTurretPosition != null)
                {
                    instance.position = ghostTurretPosition.position;
                    instance.eulerAngles = ghostTurretPosition.eulerAngles;
                }
                var view = instance.GetComponent<Views.GhostBulletBookView>();
                if (view == null)
                {
                    Debug.LogWarning("GhostBulletBookTest: GhostBulletBookView が見つかりません。");
                    return;
                }
                view.SetBulletWaitPosition(ghostBulletWaitPosition.position);
                view.SetTarget(player);
                List<int> ignorePhysicsGhostBullets = new List<int>();
                if (staticColldersInstance != null)
                {
                    // プレイヤーガード
                    Transform playerGuardInstance = null;
                    foreach (Transform child in staticColldersInstance)
                    {
                        if (child.name.Equals("PlayerGuard"))
                        {
                            playerGuardInstance = child;
                        }
                    }
                    ignorePhysicsGhostBullets.Add(playerGuardInstance.GetComponent<BoxCollider>().GetInstanceID());
                }
                view.SetIgnorePhysicsGhostBullets(ignorePhysicsGhostBullets);
                view.IsCompletedMoveToTarget.Where(x => x)
                    .Take(1)
                    .Subscribe(_ =>
                    {
                        Debug.Log($"対象の追尾が完了");
                    })
                    .AddTo(ref _disposableBag);
            }
        }

        private void OnDestroy()
        {
            _disposableBag.Dispose();
        }
    }
}
