using UnityEngine;
using Mains.Models; // PlayerModel を使うために必要
using System;

namespace Mains.Tests
{
    public class CommonPanelViewTest : MonoBehaviour
    {
        [SerializeField] private int testHealthPointMax = 100;
        [SerializeField] private int testHealthPoint = 5;

        private void OnGUI()
        {
            Rect buttonRect = new Rect(10, 70, 250, 50);

            if (GUI.Button(buttonRect, $"Set HP Max to {testHealthPointMax}"))
            {
                Debug.Log($"[テスト] HP最大値を {testHealthPointMax} に設定します");

                // シーン内から PlayerModel を探す
                PlayerModel playerModel = FindAnyObjectByType<PlayerModel>();
                if (playerModel != null)
                {
                    playerModel.SetHealthPointMax(testHealthPointMax);
                    Debug.Log($"[成功] SetHealthPointMax({testHealthPointMax}) が呼び出されました");
                }
                else
                {
                    Debug.LogWarning("PlayerModel がシーン内に見つかりませんでした。");
                }
            }

            Rect buttonRect1 = new Rect(10, 70 + 50 + 10, 250, 50);

            if (GUI.Button(buttonRect1, $"Set HP to {testHealthPoint}"))
            {
                Debug.Log($"[テスト] HPを {testHealthPoint} に設定します");

                // シーン内から PlayerModel を探す
                PlayerModel playerModel = FindAnyObjectByType<PlayerModel>();
                if (playerModel != null)
                {
                    playerModel.SetHealthPoint(testHealthPoint);
                    Debug.Log($"[成功] SetHealthPoint({testHealthPoint}) が呼び出されました");
                }
                else
                {
                    Debug.LogWarning("PlayerModel がシーン内に見つかりませんでした。");
                }
            }
        }
    }
}
