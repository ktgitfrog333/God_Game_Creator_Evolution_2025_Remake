using Mains.Commons;
using Mains.Models;
using Mains.ViewModels;
using System.Reflection;
using UnityEngine;

namespace Mains.Tests
{
    /// <summary>
    /// MissGhostAttackCustomizeViewModelのテスト
    /// </summary>
    public class MissGhostAttackCustomizeViewModelTest : MonoBehaviour
    {
        [SerializeField] private StubSO stubSO;
        private PlayerModel _model;
        // リフレクション用のフィールド情報（キャッシュ）
        private FieldInfo _playerModelField;

        private void Start()
        {
            Debug.Log($"MissGhostAttackCustomizeViewModelTest Start");
            Debug.Log($" - Section 0");
            Init();
            Execute();
            Debug.Log($"MissGhostAttackCustomizeViewModelTest End");
        }

        private void Init()
        {
            var stub = stubSO.commons.missGhostAttackCustomizeViewModel._現在のトランザクション中のオバケモデルタイプが取得できること;
            var inputs = stub.inputs;
            var outputs = stub.outputs;
            if (inputs.Length == outputs.Length)
            {
                for (int i = 0; i < inputs.Length; i++)
                {
                    int caseId = i;
                    var model = inputs[caseId].playerModel;
                    if (model != null)
                    {
                        GhostInStaticObjectStruct target = model.TransactionGhostInStaticObjectStruct;
                        var ghostTeamID = model.ghostTeamID;
                        target.ghostTeamID.Value = ghostTeamID;
                    }
                }
            }
            _model = FindAnyObjectByType<PlayerModel>();
        }

        private void Execute()
        {
            // リフレクションのフィールド情報を事前に取得（パフォーマンス向上のため）
            var viewModelType = typeof(MissGhostAttackCustomizeViewModel);
            _playerModelField = viewModelType.GetField("_playerModel", BindingFlags.NonPublic | BindingFlags.Instance);

            if (_playerModelField == null)
            {
                Debug.LogError("_playerModel フィールドが見つかりませんでした");
                return;
            }

            var stub = stubSO.commons.missGhostAttackCustomizeViewModel._現在のトランザクション中のオバケモデルタイプが取得できること;
            var inputs = stub.inputs;
            var outputs = stub.outputs;
            if (inputs.Length == outputs.Length)
            {
                for (int i = 0; i < inputs.Length; i++)
                {
                    int caseId = i;
                    GhostInStaticObjectStruct target = inputs[caseId].playerModel?.TransactionGhostInStaticObjectStruct ?? null;
                    MissGhostAttackCustomizeViewModel viewModel = new MissGhostAttackCustomizeViewModel();
                    if (!inputs[caseId].isNullPlayerModel)
                    {
                        // リフレクションを使用して _playerModel をセット
                        _playerModelField.SetValue(viewModel, _model);
                        _model?.SetTransactionGhostInStaticObjectStruct(target);
                    }
                    else
                    {
                        _playerModelField.SetValue(viewModel, null);
                    }
                    var currentGhostModelType = viewModel.CurrentGhostModelType;
                    var expected = outputs[caseId].ghostModelType;
                    var actual = currentGhostModelType;
                    var result = expected.Equals(actual);
                    if (result)
                        Debug.Log($" -- caseId: [{caseId}] Success");
                    else
                        Debug.LogError($" -- caseId: [{caseId}] Faild");
                }
            }
        }
    }
}
